# Xians Platform Configuration
XIANS-SERVER-URL=
XIANS-API-KEY=
# Docker executor image (defaults to xianix-executor:latest)
EXECUTOR-IMAGE=xianix-executor:latest
CONTAINER-MEMORY-MB=1024   # Memory limit per container in MB
CONTAINER-CPU-COUNT=1      # CPU cores per container (fractional allowed, e.g. 0.5)
CONTAINER-EXECUTION-TIMEOUT-SECONDS=900  # Hard wall-clock cap per container run; killed when exceeded (default 15 min)

# Required for the agent itself (also forwarded into every executor container).
ANTHROPIC-API-KEY=
# Optional: Claude model override
ANTHROPIC-DEPLOYMENT-NAME=claude-haiku-4-5

# CM platform tokens (GITHUB-TOKEN, AZURE-DEVOPS-TOKEN, ...) are NOT read from this file.
# Each tenant must store their own platform PAT in the Xians Secret Vault, and rules.json
# references it via "value": "secrets.GITHUB-TOKEN" (or "secrets.AZURE-DEVOPS-TOKEN").
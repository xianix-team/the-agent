# Xians Platform Configuration
XIANS-SERVER-URL=
XIANS-API-KEY=
# Docker executor image (defaults to xianix-executor:latest)
EXECUTOR-IMAGE=xianix-executor:latest
CONTAINER-MEMORY-MB=1024   # Memory limit per container in MB
CONTAINER-CPU-COUNT=1      # CPU cores per container (fractional allowed, e.g. 0.5)

# For tenant specific tokens, use the format <TENANT-ID>-GITHUB-TOKEN or <TENANT-ID>-AZURE-DEVOPS-TOKEN
# Example:
# MY-TENANT-GITHUB-TOKEN=
# MY-TENANT-AZURE-DEVOPS-TOKEN=
# MY-TENANT-ANTHROPIC-API-KEY=

## Fallbacks for when tenant specific tokens are not available

# Git auth tokens
GITHUB-TOKEN=
AZURE-DEVOPS-TOKEN=
# LLM / Anthropic
ANTHROPIC-API-KEY=
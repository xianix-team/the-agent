# Xians Platform Configuration
XIANS_SERVER_URL=
XIANS_API_KEY=

# LLM / Anthropic
ANTHROPIC_API_KEY=

# CM Platform tokens (shared across all tenants)
# Provide the token for the platform(s) you use
# For tenant specific tokens, use the format <TENANT_ID>_GITHUB_TOKEN or <TENANT_ID>_AZURE_DEVOPS_TOKEN
# Example:
# TENANT_ID_GITHUB_TOKEN=
# TENANT_ID_AZURE_DEVOPS_TOKEN=

## Fallback tokens for when tenant specific tokens are not available
GITHUB_TOKEN=
AZURE_DEVOPS_TOKEN=

## Tenant specific tokens
TENANT_ID_GITHUB_TOKEN=
TENANT_ID_AZURE_DEVOPS_TOKEN=

# Docker executor image (defaults to xianix-executor:latest)
EXECUTOR_IMAGE=xianix-executor:latest

# Container resource limits
CONTAINER_MEMORY_MB=1024   # Memory limit per container in MB
CONTAINER_CPU_COUNT=1      # CPU cores per container (fractional allowed, e.g. 0.5)

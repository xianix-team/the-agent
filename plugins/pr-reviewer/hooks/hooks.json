{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/validate-prerequisites.sh"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/notify-push.sh"
                    }
                ]
            }
        ]
    }
}
